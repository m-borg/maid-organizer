{
   "background": {
      "service_worker": "bg.js"
   },
   "action": {
      "default_icon": {
         "16": "icon-16.png",
         "32": "icon-32.png",
         "48": "icon-48.png",
         "128": "icon-128.png"
      },
      "default_title": "Options"
   },
   "content_security_policy": {
      "extension_pages": "script-src 'self'; object-src 'self'"
   },
   "description": "A neat and clean way to organize your downloads into folders based on website URLs and file types.",
   "icons": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
   },
   "manifest_version": 3,
   "minimum_chrome_version": "88",
   "name": "Maid - Download Organizer",
   "options_page": "options.html",
   "permissions": [
      "downloads",
      "storage"
   ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.1"
}